{
  "title": "Pipeline Performance",
  "uid": "leeg-pipeline",
  "tags": ["leeg", "pipeline"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Throughput (req/min)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "sum(rate(pipeline_duration_seconds_count[5m])) * 60",
        "legendFormat": "req/min"
      }]
    },
    {
      "id": 2,
      "title": "Pipeline P50 Latency (s)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "histogram_quantile(0.5, sum(rate(pipeline_duration_seconds_bucket[5m])) by (le, channel))",
        "legendFormat": "P50 {{channel}}"
      }]
    },
    {
      "id": 3,
      "title": "Pipeline P95 Latency (s)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "histogram_quantile(0.95, sum(rate(pipeline_duration_seconds_bucket[5m])) by (le, channel))",
        "legendFormat": "P95 {{channel}}"
      }]
    },
    {
      "id": 4,
      "title": "Pipeline Errors (per 5m)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "sum(increase(pipeline_errors_total[5m])) by (stage)",
        "legendFormat": "{{stage}}"
      }]
    },
    {
      "id": 5,
      "title": "Stage Latency Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "histogram_quantile(0.5, sum(rate(pipeline_stage_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "P50 {{stage}}"
        },
        {
          "datasource": {"type": "prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(pipeline_stage_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "P95 {{stage}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Rate by Stage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [{
        "datasource": {"type": "prometheus"},
        "expr": "sum(rate(pipeline_errors_total[5m])) by (stage)",
        "legendFormat": "{{stage}}"
      }]
    }
  ]
}
