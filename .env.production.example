# ── Production Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.
#
# Generate SECRET_KEY with:  openssl rand -hex 32
# Generate POSTGRES_PASSWORD with: openssl rand -hex 24

# ── Application ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-openssl-rand-hex-32
DEBUG=false
ALLOWED_ORIGINS=https://yourdomain.com

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-24
DATABASE_URL=postgresql+asyncpg://leeg:${POSTGRES_PASSWORD}@postgres:5432/leeg

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Anthropic (LLM) ────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Qdrant (vector database) ───────────────────────────────────────────────────
# For self-hosted Qdrant inside Docker: QDRANT_HOST=qdrant, QDRANT_API_KEY=
# For Qdrant Cloud: set QDRANT_HOST to your cluster URL and provide the API key
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Ollama (local LLM for Llama Guard) ────────────────────────────────────────
# For self-hosted Ollama inside Docker: OLLAMA_HOST=ollama
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# ── Twilio (SMS) ───────────────────────────────────────────────────────────────
# Get credentials at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Frontend ────────────────────────────────────────────────────────────────────
# The URL the browser uses to reach the API — must be publicly accessible
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ── Observability ──────────────────────────────────────────────────────────────
OTEL_ENDPOINT=http://otel-collector:4317
