# Leeg - Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
# See app/config.py for type definitions and defaults.

# ── App ──────────────────────────────────────────────────────────────────────
# Set to true in local development to enable /docs, /redoc, and SQL echo.
DEBUG=false

# Long random string used to sign JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000

# JWT access token lifetime.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# POSTGRES_PASSWORD is used by docker-compose.yml variable substitution
# (${POSTGRES_PASSWORD}) to set the Postgres container password AND construct
# the DATABASE_URL override for the app container. Keep it out of source control.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=change-me

# Used when running the app directly (outside Docker). Must match POSTGRES_PASSWORD.
# In Docker Compose this is overridden automatically via the compose file.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://leeg:change-me@localhost:5432/leeg

# ── Redis ─────────────────────────────────────────────────────────────────────
# DB 0: application cache (embeddings, RAG results, pipeline outputs)
REDIS_URL=redis://localhost:6379/0

# DB 1: Celery task broker (SMS background tasks)
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
# Obtain from https://console.twilio.com
# Leave TWILIO_ACCOUNT_SID empty ("") to disable outbound SMS in local dev.
# Signature validation on POST /sms/webhook is also skipped when AUTH_TOKEN is empty.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# The Twilio phone number to send SMS from, in E.164 format.
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
#
# ── ngrok (local Twilio dev) ──────────────────────────────────────────────────
# To receive real inbound SMS locally:
#   1. brew install ngrok && ngrok config add-authtoken <your-token>
#   2. ngrok http 8000
#   3. Copy the https URL (e.g. https://abc123.ngrok-free.app)
#   4. Twilio console -> Phone Numbers -> Messaging webhook:
#      https://abc123.ngrok-free.app/sms/webhook  (HTTP POST)

# ── Anthropic (Claude Haiku — Stage 3 LLM) ───────────────────────────────────
# Obtain from https://console.anthropic.com
# Used for generation, tool calling, and agentic reasoning in Stage 3.
# In production, store in AWS SSM Parameter Store (/leeg/prod/anthropic_api_key).
ANTHROPIC_API_KEY=sk-ant-...

# ── Qdrant (vector database) ──────────────────────────────────────────────────
# In Docker Compose use qdrant as the host.
QDRANT_HOST=localhost
QDRANT_PORT=6333
