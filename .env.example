# Leeg - Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
# See app/config.py for type definitions and defaults.

# ── App ──────────────────────────────────────────────────────────────────────
# Set to true in local development to enable /docs, /redoc, and SQL echo.
DEBUG=false

# Long random string used to sign JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000

# JWT access token lifetime.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# Docker Compose default shown; update host/password for production.
DATABASE_URL=postgresql+asyncpg://leeg:leeg@localhost:5432/leeg

# ── Redis ─────────────────────────────────────────────────────────────────────
# DB 0: application cache (embeddings, RAG results, pipeline outputs)
REDIS_URL=redis://localhost:6379/0

# DB 1: Celery task broker (SMS background tasks)
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
# Obtain from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# The Twilio phone number to send SMS from, in E.164 format.
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Ollama (self-hosted LLM) ──────────────────────────────────────────────────
# Ollama API base URL. In Docker Compose use http://ollama:11434
# Ensure model llama3.1:8b-instruct-q5_0 is pulled (see Phase 7 setup).
OLLAMA_HOST=http://localhost:11434

# ── Qdrant (vector database) ──────────────────────────────────────────────────
# In Docker Compose use qdrant as the host.
QDRANT_HOST=localhost
QDRANT_PORT=6333
